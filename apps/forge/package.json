{
  "name": "explore-jira-agent-assigment",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "check": "npm run test && npm run lint && npm run format:check && npm run typecheck",
    "clean": "rm -rf ./dist",
    "dev": "echo 'Not implemented'",
    "forge:deploy": "source .env && forge deploy --environment development",
    "forge:install": "source .env && forge install --site \"$SITENAME.atlassian.net\" --product jira --environment development --non-interactive",
    "forge:uninstall": "source .env && forge uninstall --site \"$SITENAME.atlassian.net\" --product jira",
    "format": "biome format --write",
    "format:check": "biome format",
    "generate": "npm run generate:openapi && npm run generate:rovo",
    "generate:openapi": "openapi-typescript",
    "generate:rovo": "tsx ./scripts/actiontypes.ts && npm run format",
    "lint": "npm run lint:check && source .env && forge lint",
    "lint:check": "biome lint",
    "lint:fix": "biome lint --write",
    "prepare": "echo 'Not implemented'",
    "preview": "echo 'Not implemented'",
    "start": "echo 'Not implemented'",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "todo": "grep -rn 'TODO' --exclude='package.json' . --color=auto || echo 'No TODOs found!'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@forge/api": "^7.1",
    "forge-ahead": "*",
    "yaml": "^2.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4",
    "@types/node": "^25.5",
    "archunit": "^2.1",
    "openapi-typescript": "^7.13",
    "tsx": "^4.21",
    "typescript": "^6.0",
    "vitest": "^4.1"
  }
}
