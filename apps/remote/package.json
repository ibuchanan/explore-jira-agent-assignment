{
  "name": "remote-agent-backend",
  "version": "0.3.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "clean": "rm -rf ./dist ./database",
    "dev": "npm run dev:tunnel && npm run dev:remote",
    "dev:remote": "tsx watch src/server.ts",
    "dev:tunnel": "source .env && zrok share reserved \"$HOSTNAME\"",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "npm run lint:check",
    "lint:check": "biome lint",
    "lint:fix": "biome lint --write",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "todo": "grep -rn 'TODO' --exclude='package.json' . --color=auto || echo 'No TODOs found!'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "forge-ahead": "*",
    "yaml": "^2.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "24",
    "tsx": "^4.22.4",
    "typescript": "^6.0",
    "vitest": "^4.1.9"
  }
}
