{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "include": ["src"],
  "compilerOptions": {
    /* Transpiling for Forge bundler (required) */
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "module": "ES2022"
  }
}
