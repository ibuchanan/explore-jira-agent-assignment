{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": [
    "tsconfig.json",
    "biome.json",
    ".github/**"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ],
      "cache": true
    },
    "test": {
      "outputs": [],
      "cache": true,
      "env": [
        "CI"
      ]
    },
    "test:coverage": {
      "outputs": [
        "coverage/**"
      ],
      "cache": true,
      "env": [
        "CI"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "lint:check": {
      "outputs": [],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "format:check": {
      "outputs": [],
      "cache": true
    },
    "check": {
      "outputs": [],
      "cache": true,
      "dependsOn": [
        "lint",
        "format:check",
        "typecheck"
      ]
    },
    "typecheck": {
      "outputs": [],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "check:arch": {
      "outputs": [],
      "cache": true
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "changelog": {
      "outputs": [],
      "cache": false
    },
    "generate": {
      "outputs": [
        "src/generated/**"
      ],
      "cache": false
    },
    "generate:openapi": {
      "outputs": [
        "src/generated/**"
      ],
      "cache": false
    },
    "generate:rovo": {
      "outputs": [
        "src/generated/**"
      ],
      "cache": false
    },
    "forge:deploy": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": false
    },
    "forge:install": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": false
    },
    "forge:register": {
      "cache": false,
      "persistent": false
    },
    "forge:uninstall": {
      "cache": false,
      "persistent": false
    },
    "dev:remote": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "dev:remote:watch": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
